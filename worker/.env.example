# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (若使用 API，Max 帳號則不需要)
# ANTHROPIC_API_KEY=your-api-key

# FlipHTML5 電子書 API
FLIPHTML5_ACCESS_KEY_ID=your-access-key-id
FLIPHTML5_ACCESS_KEY_SECRET=your-access-key-secret

# CORS 白名單（正式環境的前端網域）
PUBLIC_URL=https://weekly.tzuchi.org.tw

# Firebase Cloud Messaging (推播通知)
# 方式一：檔案路徑（本地開發）
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# 方式二：JSON 字串（生產環境 / Cloudflare Workers）
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Drive Service Account（讀取週報圖片資料夾用）
# 整串 JSON key 貼成單行字串。若未設定，import 會 fallback 到使用者 OAuth provider_token
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"tzuchi-weekly-15d53","client_email":"driveapi@tzuchi-weekly-15d53.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}

# External PDF reader (/books/r/ext) — comma-separated hostnames the reader will accept.
# Leave empty to reject all external URLs. See spec 2026-07-03-external-pdf-reader-design §8.
ALLOWED_PDF_HOSTS=tool.tzuchi-org.tw
